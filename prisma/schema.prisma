generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── CORE SHIPMENT DATA ──────────────────────────────────────────────────────

model Shipment {
  id                     String   @id @default(cuid())
  awb                    String   @unique
  pickup_date            DateTime
  service_node           String   // pickup centre / node
  hub_name               String   // hub where processed

  // FM fields
  pc_to_hub              String?  // manifest number
  pc_to_hub_created_on   DateTime?
  pc_to_hub_flight_no    String?

  // MAWB fields
  mawb                   String?
  mawb_date              DateTime?
  port_of_origin         String?
  clearance_type_oc      String?  // CSB V / CSB VI / Commercial (OC)
  oc_vendor              String?

  // Destination fields
  dest_clearance_type    String?  // Formal / Informal / T86
  service_type           String?  // Commercial / Courier
  point_of_entry         String?  // JFK / LAX / ORD
  injection_port         String?  // e.g. JFK-Shipbae-WC
  dc_partner             String?  // extracted from injection_port
  country                String?  // destination country

  // Shipment details
  pkg_type               String   // box / flyer
  n_packages             Int      @default(1)
  length_cm              Float
  width_cm               Float
  height_cm              Float
  gross_weight           Float    // kg
  line_items             Int      @default(1)

  // Last mile
  lm_carrier             String?
  lm_shipping_method     String?
  dest_zip               String?

  // Metadata
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  costs      ShipmentCost?
  overrides  CostOverride[]
}

model ShipmentCost {
  id                   String   @id @default(cuid())
  awb                  String   @unique
  shipment             Shipment @relation(fields: [awb], references: [awb], onDelete: Cascade)

  pickup_cost          Float    @default(0)
  pickup_source        String   @default("calculated") // calculated | avg | override
  fm_cost              Float    @default(0)
  fm_source            String   @default("calculated")
  hub_cost             Float    @default(0)
  hub_source           String   @default("calculated")
  oc_cost              Float    @default(0)
  oc_source            String   @default("calculated")
  mm_cost              Float    @default(0)
  mm_source            String   @default("calculated")
  dh_cost              Float    @default(0)
  dh_source            String   @default("calculated")
  dc_clearance_cost    Float    @default(0)
  dc_clearance_source  String   @default("calculated")
  dropoff_cost         Float    @default(0)
  dropoff_source       String   @default("calculated")
  lm_cost              Float    @default(0)
  lm_source            String   @default("calculated")

  total_cost           Float    @default(0)
  computed_at          DateTime @default(now())
}

model CostOverride {
  id              String   @id @default(cuid())
  awb             String
  shipment        Shipment @relation(fields: [awb], references: [awb], onDelete: Cascade)
  node            String   // pickup | fm | hub | oc | mm | dh | dc | dropoff | lm
  override_flag   Boolean  @default(false)
  override_cost   Float?
  prev_cost       Float?
  override_reason String?
  updated_by      String?
  updated_at      DateTime @default(now())

  @@index([awb, node])
}

// ─── 5.1 PICKUP MASTER ───────────────────────────────────────────────────────

model PickupCostMaster {
  id                         String   @id @default(cuid())
  pickup_node                String
  delivery_node              String
  monthly_fixed_charge       Float
  threshold_weight           Float    @default(0)
  cost_per_kg_above_threshold Float   @default(0)
  start_date                 DateTime
  end_date                   DateTime
  created_at                 DateTime @default(now())

  @@index([pickup_node, delivery_node])
}

model PickupAvgMaster {
  id              String   @id @default(cuid())
  service_node    String
  avg_cost_per_kg Float
  start_date      DateTime
  end_date        DateTime
}

// ─── 5.2 FIRST MILE MASTER ───────────────────────────────────────────────────

model FmMaster {
  id                    String   @id @default(cuid())
  flight_no             String?  // manifest key
  origin_node           String
  delivery_node         String
  mode_of_transport     String   // Air | Rail | Road
  cost_per_kg           Float
  fixed_cost            Float    @default(0)
  start_date            DateTime
  end_date              DateTime
  created_at            DateTime @default(now())

  @@index([origin_node, delivery_node])
}

model FmAvgMaster {
  id              String   @id @default(cuid())
  service_node    String
  avg_cost_per_kg Float
  start_date      DateTime
  end_date        DateTime
}

// ─── 5.3 HUB MASTER ──────────────────────────────────────────────────────────

model HubCostMaster {
  id                       String   @id @default(cuid())
  hub_name                 String
  monthly_fixed_cost       Float
  monthly_threshold_weight Float    @default(0)
  threshold_per_kg_cost    Float    @default(0)
  start_date               DateTime
  end_date                 DateTime
  created_at               DateTime @default(now())
}

model Holiday {
  id       String   @id @default(cuid())
  date     DateTime
  hub_name String   // 'ALL' means every hub
  reason   String?

  @@unique([date, hub_name], name: "date_hub_name")
}

// ─── 5.4 ORIGIN CUSTOMS MASTER ───────────────────────────────────────────────

model OcMaster {
  id                    String   @id @default(cuid())
  vendor_name           String
  port_of_origin        String
  clearance_type        String   // CSB V | CSB VI | Commercial
  charge_type           String   // Per MAWB | Per Shipment | Per Box | Per KG
  cost                  Float
  threshold_mawb_weight Float    @default(0)
  threshold_per_kg_cost Float    @default(0)
  start_date            DateTime
  end_date              DateTime
  created_at            DateTime @default(now())

  @@index([vendor_name, port_of_origin, clearance_type])
}

model OcAvgMaster {
  id              String   @id @default(cuid())
  vendor_name     String
  clearance_type  String
  avg_cost_per_kg Float
  start_date      DateTime
  end_date        DateTime
}

// ─── 5.5 MIDDLE MILE MASTER ──────────────────────────────────────────────────

model MmMaster {
  id                  String   @id @default(cuid())
  airline             String
  origin_port         String
  dest_port           String
  rate_per_kg         Float
  fixed_cost_per_mawb Float    @default(0)
  start_date          DateTime
  end_date            DateTime
  created_at          DateTime @default(now())
}

model MmAvgMaster {
  id              String   @id @default(cuid())
  origin_port     String
  avg_cost_per_kg Float
  start_date      DateTime
  end_date        DateTime
}

// ─── 5.6 DESTINATION HANDLING MASTER ─────────────────────────────────────────

model DhMaster {
  id              String   @id @default(cuid())
  dc_partner      String
  clearance_type  String   // T86 | FORMAL | INFORMAL
  cost_head_name  String   // Airline Recovery | ISC | ADC | Pallet | Handover
  charge_type     String   // Per MAWB | Per KG | Per Shipment | Per Carton | Per Pallet
  cost            Float
  pallet_weight   Float?   // only for Per Pallet charge type
  start_date      DateTime
  end_date        DateTime
  created_at      DateTime @default(now())

  @@index([dc_partner, clearance_type])
}

model DhAvgMaster {
  id              String   @id @default(cuid())
  clearance_type  String
  point_of_entry  String
  avg_cost_per_kg Float
  start_date      DateTime
  end_date        DateTime
}

// ─── 5.7 DESTINATION CLEARANCE MASTER ────────────────────────────────────────

model DcClearanceMaster {
  id             String   @id @default(cuid())
  country        String
  vendor_name    String
  clearance_type String   // Formal | Informal | T86
  charge_type    String   // Per KG | Per Shipment | Per Line Item | Fixed Per MAWB | Max Per MAWB
  cost           Float
  start_date     DateTime
  end_date       DateTime
  created_at     DateTime @default(now())

  @@index([country, clearance_type])
}

model DcClearanceAvgMaster {
  id              String   @id @default(cuid())
  country         String
  clearance_type  String
  avg_cost_per_kg Float
  start_date      DateTime
  end_date        DateTime
}

// ─── 5.8 DROP-OFF MASTER ─────────────────────────────────────────────────────

model DropoffMaster {
  id                  String   @id @default(cuid())
  country             String
  partner             String
  fixed_cost_per_mawb Float    @default(0)
  cost_per_kg         Float    @default(0)
  start_date          DateTime
  end_date            DateTime
  created_at          DateTime @default(now())

  @@index([country, partner])
}

model DropoffAvgMaster {
  id              String   @id @default(cuid())
  country         String
  partner         String
  avg_cost_per_kg Float
  start_date      DateTime
  end_date        DateTime
}

// ─── 5.9 LAST MILE MASTERS ───────────────────────────────────────────────────

model LmCarrierConfig {
  id                           String   @id @default(cuid())
  carrier_name                 String
  shipping_method              String
  vol_factor                   Float    @default(5000)
  carrier_type                 String   // Regional | National
  rate_type                    String   // LBS | OZ
  residential_surcharge        Float    @default(0)
  residential_threshold_weight Float?
  net_chargeable_weight_type   String   @default("Chargeable Weight")
  net_chargeable_weight_threshold Float?
  fuel_surcharge_pct           Float    @default(0)
  partner_margin_pct           Float    @default(0)
  country                      String   @default("USA")
  start_date                   DateTime
  end_date                     DateTime
  created_at                   DateTime @default(now())

  @@unique([carrier_name, shipping_method, country])
}

model LmZoneMapping {
  id               String   @id @default(cuid())
  country          String
  carrier_name     String
  shipping_method  String
  destination_key  String   // ZIP or SCF prefix
  zone             String
  injection_port   String
  start_date       DateTime
  end_date         DateTime

  @@index([carrier_name, injection_port, destination_key])
}

model LmRateCard {
  id              String   @id @default(cuid())
  country         String
  zone            String
  carrier_name    String
  shipping_method String
  injection_port  String
  unit            String   // OZ | LBS
  unit_value      Float    // weight slab upper bound
  rate            Float
  start_date      DateTime
  end_date        DateTime

  @@index([carrier_name, shipping_method, zone, injection_port])
}

model LmDasMaster {
  id              String   @id @default(cuid())
  country         String
  carrier_name    String
  shipping_method String
  zipcode         String
  das_type        String   // DAS | EDAS | RAS
  surcharge_amount Float
  start_date      DateTime
  end_date        DateTime

  @@index([carrier_name, zipcode])
}

model LmSurchargeMaster {
  id              String   @id @default(cuid())
  carrier_name    String
  surcharge_type  String   // Fuel | Residential | Additional Handling | Large Package | Peak | Address Correction
  charge_type     String   // Fixed | Percent
  value           Float
  condition_type  String?  // Weight | Dimension | Date Range | Always
  condition_value Float?
  start_date      DateTime
  end_date        DateTime

  @@index([carrier_name, surcharge_type])
}

model LmAvgMaster {
  id              String   @id @default(cuid())
  carrier_name    String
  shipping_method String
  zone            String?
  avg_cost_per_kg Float
  country         String   @default("USA")
  start_date      DateTime
  end_date        DateTime
}
